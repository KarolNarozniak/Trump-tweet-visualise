# Global config lookup
TG_CONFIG_PATH=config/defaults.toml

# Build defaults
TG_BUILD_INPUT_CSV=tweets_01-08-2021.csv
TG_BUILD_OUTPUT_DIR=data/processed
TG_BUILD_MIN_MENTION_COUNT=1
TG_BUILD_GLOBAL_MIN_MENTIONS=8
TG_BUILD_INCLUDE_RETWEETS=true
TG_BUILD_HEAT_DECAY=0.85
TG_BUILD_LAYOUT_SEED=42

# App defaults
TG_APP_PROCESSED_DIR=data/processed
TG_APP_INCLUDE_HUB=true
TG_APP_ALWAYS_LABEL_TOP_NODES=false
TG_APP_PLAYBACK_SPEED=8.0
TG_APP_NODE_SIZE_MULTIPLIER=2.0
TG_APP_LAYOUT_SPREAD=1.0
TG_APP_INITIAL_ZOOM_BOOST=0.8
TG_APP_GRAPH_HEIGHT_PX=1000

# Runtime defaults
TG_RUNTIME_STREAMLIT_HOST=0.0.0.0
TG_RUNTIME_STREAMLIT_PORT=3001
TG_RUNTIME_DOCS_HOST=0.0.0.0
TG_RUNTIME_DOCS_PORT=3002
TG_RUNTIME_DOCS_URL=http://localhost:3002
TG_RUNTIME_DOCS_SITE_DIR=docs-site

# App metadata and legal copy
TG_META_APP_NAME=Trump Graph
TG_META_LOGO_PATH=logo.png
TG_META_DATA_SOURCE_URL=https://www.thetrumparchive.com/
TG_META_REPOSITORY_URL=https://github.com/KarolNarozniak/Trump-tweet-visualise
TG_META_DISCLAIMER_TEXT=Disclaimer: This visualization is a student educational project for studying time-dependent graph behavior. It is not intended as political endorsement, defamation, or factual/legal judgment about any person.
TG_META_ABOUT_TEXT=Trump Graph is a student project focused on temporal network analysis. Its purpose is to explore how mentions and co-mentions evolve over time in archived tweet data. The project is purely educational.
